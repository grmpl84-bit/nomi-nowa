<?xml version="1.0" encoding="utf-8"?>
<!-- Same symbol as ic_launcher_foreground.xml (arch "n" + eye + sound bars),
     without the speech-bubble background — used inline in the app header,
     where the background color is already provided by the gradient behind it. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Letter "n" - arch shape -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:pathData="M21,72v-18c0,-14 10,-22 18,-22s18,8 18,22v18" />

    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M21,72v-18c0,-14 10,-22 18,-22s18,8 18,22v18" />

    <!-- "Eye" -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M42.5,45 a3.5,3.5 0 1,0 7,0 a3.5,3.5 0 1,0 -7,0" />

    <!-- Sound wave bars -->
    <path android:fillColor="#FFFFFF" android:pathData="M63,48h4v20h-4z" />
    <path android:fillColor="#FFFFFF" android:pathData="M70,44h4v28h-4z" />
    <path android:fillColor="#FFFFFF" android:pathData="M77,40h4v36h-4z" />

</vector>
